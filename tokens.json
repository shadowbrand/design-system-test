{
  "Design system/Default": {
    "colors": {
      "neutral": {
        "default": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "color",
          "$value": "#ffffff"
        },
        "onDefault": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "color",
          "$value": "#000000"
        },
        "accent": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "color",
          "$value": "#0059ff"
        },
        "muted": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "color",
          "$value": "#adadad"
        }
      }
    },
    "spacing": {
      "xs": {
        "$extensions": {
          "com.figma.scopes": [
            "ALL_SCOPES"
          ],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "number",
        "$value": "6"
      },
      "sm": {
        "$type": "number",
        "$value": "8"
      },
      "md": {
        "$extensions": {
          "com.figma.scopes": [
            "ALL_SCOPES"
          ],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "number",
        "$value": "20"
      }
    },
    "text": {
      "card": {
        "title": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "text",
          "$value": "Card title"
        },
        "body": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "text",
          "$value": "Card body text card body text card body text card body text."
        },
        "CTA": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "text",
          "$value": "Card CTA"
        },
        "status": {
          "$extensions": {
            "com.figma.scopes": [
              "ALL_SCOPES"
            ],
            "com.figma.hiddenFromPublishing": false
          },
          "$type": "text",
          "$value": "Card status"
        }
      }
    },
    "fontFamilies": {
      "neue-haas-unica-w1g": {
        "$type": "fontFamilies",
        "$value": "Neue Haas Unica W1G"
      }
    },
    "lineHeights": {
      "0": {
        "$type": "lineHeights",
        "$value": "28"
      },
      "1": {
        "$type": "lineHeights",
        "$value": "55"
      },
      "2": {
        "$type": "lineHeights",
        "$value": "84"
      }
    },
    "fontWeights": {
      "neue-haas-unica-w1g-0": {
        "$type": "fontWeights",
        "$value": "Regular"
      }
    },
    "fontSize": {
      "0": {
        "$type": "fontSizes",
        "$value": "22"
      },
      "1": {
        "$type": "fontSizes",
        "$value": "55"
      },
      "2": {
        "$type": "fontSizes",
        "$value": "84"
      }
    },
    "letterSpacing": {
      "0": {
        "$type": "letterSpacing",
        "$value": "-5%"
      },
      "1": {
        "$type": "letterSpacing",
        "$value": "-1%"
      },
      "2": {
        "$type": "letterSpacing",
        "$value": "1%"
      }
    },
    "paragraphSpacing": {
      "0": {
        "$type": "paragraphSpacing",
        "$value": "0"
      }
    },
    "textCase": {
      "none": {
        "$type": "textCase",
        "$value": "none"
      }
    },
    "textDecoration": {
      "none": {
        "$type": "textDecoration",
        "$value": "none"
      }
    },
    "paragraphIndent": {
      "0": {
        "$type": "dimension",
        "$value": "0px"
      }
    },
    "Display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{fontFamilies.neue-haas-unica-w1g}",
        "fontWeight": "{fontWeights.neue-haas-unica-w1g-0}",
        "fontSize": "{fontSize.2}",
        "lineHeight": "{lineHeights.2}",
        "letterSpacing": "{letterSpacing.0}"
      }
    },
    "Heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{fontFamilies.neue-haas-unica-w1g}",
        "fontWeight": "{fontWeights.neue-haas-unica-w1g-0}",
        "fontSize": "{fontSize.1}",
        "lineHeight": "{lineHeights.1}",
        "letterSpacing": "{letterSpacing.1}"
      }
    },
    "Body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{fontFamilies.neue-haas-unica-w1g}",
        "fontWeight": "{fontWeights.neue-haas-unica-w1g-0}",
        "fontSize": "{fontSize.0}",
        "lineHeight": "{lineHeights.0}",
        "letterSpacing": "{letterSpacing.2}"
      }
    },
    "radius": {
      "sm": {
        "$type": "borderRadius",
        "$value": "4"
      },
      "md": {
        "$type": "borderRadius",
        "$value": "8"
      }
    },
    "drop-shadow": {
      "sm": {
        "$type": "boxShadow",
        "$value": {
          "x": "0",
          "y": "4",
          "blur": "4",
          "spread": "0",
          "color": "{colors.neutral.muted}",
          "type": "dropShadow"
        }
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "Design system/Default"
    ]
  }
}